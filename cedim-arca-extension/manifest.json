{
  "manifest_version": 3,
  "name": "CEDIM Asistente ARCA",
  "version": "0.1.0",
  "description": "Asistente de carga para Comprobantes en Línea ARCA/AFIP.",
  "permissions": ["storage", "tabs", "activeTab", "scripting"],
  "host_permissions": [
    "https://*.afip.gob.ar/*",
    "https://*.arca.gob.ar/*",
    "http://localhost:5173/*",
    "https://*.supabase.co/*",
    "https://*.github.io/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.afip.gob.ar/*",
        "https://*.arca.gob.ar/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}